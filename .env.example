# WoL-Monkey Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# Rules:
#   - Only bootstrap/infrastructure concerns belong here.
#   - All user-facing settings are stored in PostgreSQL and managed via the UI.

# ---------------------------------------------------------------------------
# Database (required)
# ---------------------------------------------------------------------------
POSTGRES_USER=wol
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=wolmonkey
DATABASE_URL=postgresql+asyncpg://wol:CHANGE_ME@db:5432/wolmonkey

# ---------------------------------------------------------------------------
# Application secret (required)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
# Must be overridden in production — app will warn on startup if default.
# ---------------------------------------------------------------------------
APP_SECRET=CHANGE_ME_IN_PRODUCTION_USE_A_LONG_RANDOM_STRING

# ---------------------------------------------------------------------------
# Bind address (default: all interfaces on port 8000, behind Caddy)
# ---------------------------------------------------------------------------
BIND_HOST=0.0.0.0
BIND_PORT=8000

# ---------------------------------------------------------------------------
# Trusted reverse proxies
# Comma-separated IPs or CIDRs of proxies whose X-Forwarded-* headers are trusted.
# Set to the Docker compose network CIDR when running behind Caddy.
# Leave empty to trust no proxies (direct mode without reverse proxy).
# ---------------------------------------------------------------------------
TRUSTED_PROXIES=172.20.0.0/16

# ---------------------------------------------------------------------------
# External port exposure (informational — actual binding is in docker-compose.yml)
# Used by the app for URL generation and wizard hints only.
# ---------------------------------------------------------------------------
EXTERNAL_HTTP_PORT=80
EXTERNAL_HTTPS_PORT=443

# ---------------------------------------------------------------------------
# Bootstrap toggles
# ---------------------------------------------------------------------------
DEBUG=false
LOG_LEVEL=INFO
